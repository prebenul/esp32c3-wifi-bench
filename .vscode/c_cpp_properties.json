{
  "configurations": [
    {
      "name": "ESP32-C3 (PlatformIO)",
      "includePath": [
        "${workspaceFolder}/src",
        "${workspaceFolder}/.pio/libdeps/esp32-c3-supermini/**",
        "${env:USERPROFILE}/.platformio/packages/framework-arduinoespressif32/cores/esp32",
        "${env:USERPROFILE}/.platformio/packages/framework-arduinoespressif32/cores/esp32/**",
        "${env:USERPROFILE}/.platformio/packages/framework-arduinoespressif32/libraries/**",
        "${env:USERPROFILE}/.platformio/packages/framework-arduinoespressif32/tools/**",
        "${env:USERPROFILE}/.platformio/packages/toolchain-riscv32-esp/riscv32-esp-elf/include/**",
        "${env:HOME}/.platformio/packages/framework-arduinoespressif32/cores/esp32",
        "${env:HOME}/.platformio/packages/framework-arduinoespressif32/cores/esp32/**",
        "${env:HOME}/.platformio/packages/framework-arduinoespressif32/libraries/**",
        "${env:HOME}/.platformio/packages/toolchain-riscv32-esp/riscv32-esp-elf/include/**",
        "${workspaceFolder}/**"
      ],
      "defines": [
        "ARDUINO=10816",
        "ESP32",
        "ESP32C3",
        "CONFIG_IDF_TARGET_ESP32C3",
        "CORE_DEBUG_LEVEL=0",
        "F_CPU=160000000L"
      ],
      "compilerPath": "${env:USERPROFILE}/.platformio/packages/toolchain-riscv32-esp/bin/riscv32-esp-elf-gcc",
      "cStandard": "c17",
      "cppStandard": "gnu++17",
      "intelliSenseMode": "gcc-x64",
      "forcedInclude": [],
      "browse": {
        "path": [
          "${workspaceFolder}",
          "${workspaceFolder}/.pio/libdeps/esp32-c3-supermini",
          "${env:USERPROFILE}/.platformio/packages/framework-arduinoespressif32",
          "${env:HOME}/.platformio/packages/framework-arduinoespressif32"
        ],
        "limitSymbolsToIncludedHeaders": false
      }
    }
  ],
  "version": 4
}
